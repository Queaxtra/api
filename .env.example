# Application mode. Use `production` for live deployments.
NODE_ENV=development
# Port the API server listens on.
PORT=3000
# Host interface to bind to. `0.0.0.0` is typical behind a reverse proxy.
HOST=0.0.0.0
# Max accepted JSON / form body size to limit oversized payload abuse.
BODY_LIMIT=16kb
# Maximum lifetime for a single HTTP request.
REQUEST_TIMEOUT_MS=15000
# Maximum time allowed for incoming request headers to complete.
HEADERS_TIMEOUT_MS=16000
# How long keep-alive connections stay open.
KEEP_ALIVE_TIMEOUT_MS=5000
# Max graceful shutdown wait time after SIGTERM / SIGINT.
SHUTDOWN_TIMEOUT_MS=10000
# Whether risky / expensive endpoints require an API key.
REQUIRE_API_KEY=true
# Comma-separated API key list. Clients must send one via the `X-Api-Key` header.
# Do not keep this sample value in production; replace it with your own strong secret.
API_KEYS=fy_live_12345
# Allowed CORS origins. Put the frontend domain(s) that will call this API from a browser.
# Do not just put the API domain unless that is actually the browser origin.
CORS_ORIGINS=https://api.fatih.live
# Request limit for expensive endpoints within the configured window.
EXPENSIVE_ROUTE_LIMIT=20
# Rate limit window in milliseconds.
EXPENSIVE_ROUTE_WINDOW_MS=60000
